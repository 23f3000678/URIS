// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CORE_ADMIN
  TECHNICAL_LEAD
  OPERATIONS_LEAD
  RESEARCH_LEAD
  OPERATIONS_PROGRAM_MANAGER
  TECHNICAL_INTERN
  OPERATIONS_INTERN
  RESEARCH_INTERN
  OBSERVER_TEAM_LEAD
  COLLABORATOR_LEAD
  ORENDA_MEMBER
  PAST_EMPLOYEE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String     // bcrypt hash only — never plain text
  name      String     @default("")   // display name supplied at registration
  role      Role       @default(TECHNICAL_INTERN)
  status    String     @default("active")  // "active" | "pending" | "alumni"
  createdAt DateTime   @default(now())
  intern    Intern?
  teams     UserTeam[]
}

model Intern {
  id                String            @id @default(uuid())
  userId            String?           @unique
  user              User?             @relation(fields: [userId], references: [id])
  
  // Public Portfolio Data
  slug              String?           @unique // for stemonef.com/portfolio/john-doe
  profilePic        String?
  contactNumber     String?
  bio               String?
  linkedinUrl       String?
  skills            String[]          @default([])
  
  overrideScore     Float?
  reservedUntil     DateTime?         // soft reservation expiry
  createdAt         DateTime          @default(now())
  availabilitySlots AvailabilitySlot[]
  tasks             Task[]
  credibility       CredibilityScore?
  capacityScore     CapacityScore?
  reviews           Review[]
  scoreHistory      ScoreHistory[]
}

model AvailabilitySlot {
  id                String   @id @default(uuid())
  internId          String
  intern            Intern   @relation(fields: [internId], references: [id])
  weekStart         DateTime @db.Date
  weekEnd           DateTime @db.Date
  maxFreeBlockHours Decimal
  busyBlocks        Json
  submittedAt       DateTime @default(now()) @updatedAt

  @@unique([internId, weekStart])
}

model Task {
  id            String    @id @default(uuid())
  planeTaskId   String    @unique
  internId      String
  title         String
  complexity    Float
  progressPct   Int       @default(0)
  status        String    @default("active")
  hasBlocker    Boolean   @default(false)
  blockerType   String?
  skills        String[]
  deadline      DateTime?
  lastUpdatedAt DateTime
  deletedAt     DateTime? // Soft delete - tasks removed for wrong assignment etc.
  
  // Visibility & Access metadata
  isOperational Boolean   @default(false)
  teamId        String?
  observerIds   String[]  @default([])
  collaboratorIds String[] @default([])

  createdAt     DateTime  @default(now())

  intern        Intern    @relation(fields: [internId], references: [id])
  reviews       Review[]
}

model CredibilityScore {
  id                 String   @id @default(uuid())
  internId           String   @unique
  updateFrequency    Float
  deadlineAdherence  Float
  throughputAccuracy Float
  score              Float
  computedAt         DateTime @default(now())

  intern             Intern   @relation(fields: [internId], references: [id])
}

model CapacityScore {
  id            String   @id @default(uuid())
  internId      String   @unique
  baseCapacity  Float
  tli           Float
  credibility   Float
  finalCapacity Float
  capacityLabel String
  updatedAt     DateTime @default(now())

  intern        Intern   @relation(fields: [internId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  internId   String
  intern     Intern   @relation(fields: [internId], references: [id])
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id])
  quality    Float
  timeliness Float
  initiative Float
  complexity Float
  createdAt  DateTime @default(now())

  @@index([taskId])
}

model Alert {
  id        String   @id @default(uuid())
  internId  String
  type      String
  taskId    String?
  message   String
  severity  String   @default("warning")  // "warning" | "critical"
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([internId])
  @@index([severity])
  @@index([resolved])
}

model ScoreHistory {
  id        String   @id @default(uuid())
  internId  String
  intern    Intern   @relation(fields: [internId], references: [id])
  score     Float
  type      String   // "performance" | "credibility" | "capacity"
  createdAt DateTime @default(now())
}

model SyncLog {
  id        String   @id @default(uuid())
  internId  String?
  filename  String
  status    String   @default("SUCCESS") // "SUCCESS" | "FAILED"
  error     String?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Multi-Team Support
// ---------------------------------------------------------------------------

model Team {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  members     UserTeam[]
}

model UserTeam {
  id       String    @id @default(uuid())
  userId   String
  teamId   String
  role     String    @default("member")  // "member" | "lead"
  joinedAt DateTime  @default(now())
  leftAt   DateTime?                     // null = currently active member

  user     User      @relation(fields: [userId], references: [id])
  team     Team      @relation(fields: [teamId], references: [id])

  @@index([userId])
  @@index([teamId])
  @@index([leftAt])
}

// ---------------------------------------------------------------------------
// Activity Tracking
// ---------------------------------------------------------------------------

model Activity {
  id        String   @id @default(uuid())
  userId    String                        // always set — activity is user-specific
  type      String                        // ACTIVITY_TYPES constant: LOGIN, LOGOUT, TASK_WORK, IDLE
  duration  Int?                          // seconds; null for point-in-time events (LOGIN/LOGOUT)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}

// ---------------------------------------------------------------------------
// Audit Log
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?                      // null for system-generated events
  action    String                       // e.g. "LOGIN", "CREATE_TASK"
  entity    String                       // e.g. "USER", "TASK", "SCORE"
  entityId  String?                      // id of the affected record
  metadata  Json?                        // arbitrary extra context
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// System Config
// ---------------------------------------------------------------------------

model Config {
  key       String   @id                 // unique setting name, e.g. "availabilityDeadline"
  value     Json                         // arbitrary JSON value
  updatedAt DateTime @default(now()) @updatedAt
}

// ---------------------------------------------------------------------------
// Weekly Digest
// ---------------------------------------------------------------------------
// One row per intern per week. Written by the digest scheduler every Monday.
// Provides a point-in-time snapshot for trend analysis and admin review.

model InternDigest {
  id               String   @id @default(uuid())
  internId         String
  weekStart        DateTime @db.Date      // Monday of the digest week
  capacityScore    Float                  // snapshot from ScoreHistory
  credibilityScore Float                  // snapshot from CredibilityScore
  performanceIndex Float                  // rolling RPI at time of digest
  activeTasks      Int
  completedTasks   Int
  openAlerts       Int
  generatedAt      DateTime @default(now())

  @@unique([internId, weekStart])
  @@index([internId])
  @@index([weekStart])
}
